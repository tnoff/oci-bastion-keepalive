# EnvironmentFile for rotate-session.service.
# Copy to ~/.config/oke-rotator/rotate_session.env and fill in.
# systemd does NOT expand $VARS or shell syntax here -- plain KEY=value only
# (the script itself expands a leading ~ in the SSH key paths).

# --- required: your OKE cluster + bastion OCIDs ---
OKE_CLUSTER_OCID=
OKE_BASTION_OCID=

# --- optional: defaults shown, uncomment to override ---
#OCI_REGION=us-sanjose-1
#OCI_PROFILE=DEFAULT
#OCI_CONFIG_FILE=~/.oci/config
#SESSION_TTL=10800
#ROTATE_LEAD=300
#ROTATE_RETRY=30
#DRAIN_SECONDS=10
#FRONT_PORT=6443
#INTERNAL_PORTS=7001,7002
#TARGET_PORT=6443
#SSH_PUBLIC_KEY=~/.ssh/id_rsa.pub
#SSH_PRIVATE_KEY=~/.ssh/id_rsa
#HEALTH_TIMEOUT=90
#SSH_SETTLE=5
#SSH_ATTEMPTS=6
#SSH_RETRY=5

# --- optional: managed port-forwards (one per PORT_FORWARD_<n>, gaps OK) ---
# Value: <namespace>/<kind>/<name>:<localPort>:<remotePort>
# <kind> is svc/service, pod, or deploy/deployment. Each is held for the
# daemon's life and reconnects to a fresh pod per connection, so it never goes
# stale the way a hand-run `kubectl port-forward` does.
#PORT_FORWARD_1=monitoring/svc/grafana:3000:3000
#PORT_FORWARD_2=monitoring/svc/mimir:9009:9009
#KUBECONFIG=~/.kube/config
#KUBE_CONTEXT=
